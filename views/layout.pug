doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= title
    link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Space+Grotesk:wght@400;700&display=swap", rel="stylesheet")
    style.
      :root {
        --bg-color: #0d0c1d;
        --card-bg: #1b1931;
        --accent-cyan: #06b6d4;
        --accent-pink: #d946ef;
        --text-color: #f1f5f9;
        --text-muted: #94a3b8;
        --border-color: #2e2a53;
        --neon-gradient: linear-gradient(135deg, #06b6d4 0%, #d946ef 100%);
      }
      body {
        font-family: 'Space Grotesk', sans-serif;
        background-color: var(--bg-color);
        color: var(--text-color);
        margin: 0;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 100vh;
        background-image: radial-gradient(circle at 50% 50%, #1e1b4b 0%, #0d0c1d 80%);
      }
      .container {
        max-width: 800px;
        width: 100%;
        background: var(--card-bg);
        padding: 3rem;
        border-radius: 28px;
        box-shadow: 0 0 40px rgba(6, 182, 212, 0.1);
        border: 1px solid var(--border-color);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .container:hover {
        transform: translateY(-4px);
        box-shadow: 0 0 60px rgba(217, 70, 239, 0.15);
      }
      header {
        text-align: center;
        margin-bottom: 2rem;
      }
      h1 {
        font-size: 3.2rem;
        font-weight: 800;
        background: var(--neon-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0;
        letter-spacing: -2px;
        text-transform: uppercase;
      }
      .subtitle {
        text-align: center;
        color: var(--text-muted);
        font-size: 1.1rem;
        margin-top: 0.5rem;
      }
      nav {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin: 1.5rem 0 2.5rem 0;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1.5rem;
      }
      nav a {
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 700;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: color 0.2s ease, text-shadow 0.2s ease;
      }
      nav a:hover, nav a.active {
        color: var(--accent-cyan);
        text-shadow: 0 0 10px rgba(6, 182, 212, 0.5);
      }
      p {
        line-height: 1.8;
        color: var(--text-muted);
        font-size: 1.1rem;
      }
      .highlight {
        color: var(--accent-cyan);
        font-weight: 700;
      }
      .game-panel {
        background: rgba(13, 12, 29, 0.6);
        border: 1px solid var(--border-color);
        padding: 2.5rem;
        border-radius: 20px;
        text-align: center;
        margin-bottom: 2rem;
      }
      .input-group {
        margin: 2rem 0;
        display: flex;
        justify-content: center;
        gap: 1rem;
      }
      input[type="number"], input[type="text"] {
        font-family: 'Space Grotesk', sans-serif;
        background: var(--bg-color);
        border: 2px solid var(--border-color);
        color: var(--text-color);
        padding: 1rem;
        border-radius: 12px;
        font-size: 1.3rem;
        outline: none;
        transition: border-color 0.2s ease;
      }
      input[type="number"] {
        width: 120px;
        text-align: center;
      }
      input[type="text"] {
        width: 250px;
      }
      input[type="number"]:focus, input[type="text"]:focus {
        border-color: var(--accent-cyan);
      }
      .btn {
        font-family: 'Space Grotesk', sans-serif;
        background: var(--neon-gradient);
        color: #0d0c1d;
        border: none;
        padding: 1rem 2.5rem;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 4px 15px rgba(6, 182, 212, 0.4);
      }
      .btn:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(217, 70, 239, 0.4);
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        font-size: 1rem;
        text-align: left;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-color);
      }
      th, td {
        padding: 1rem 1.5rem;
      }
      th {
        background: rgba(6, 182, 212, 0.1);
        color: var(--accent-cyan);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
        border-bottom: 2px solid var(--border-color);
      }
      tr {
        border-bottom: 1px solid var(--border-color);
        background-color: rgba(27, 25, 49, 0.4);
        transition: background-color 0.2s ease;
      }
      tr:last-child {
        border-bottom: none;
      }
      tr:hover {
        background-color: rgba(217, 70, 239, 0.05);
      }
      .score-badge {
        background: rgba(217, 70, 239, 0.15);
        color: var(--accent-pink);
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.95rem;
        font-weight: 700;
      }
      .list-item {
        background: rgba(6, 182, 212, 0.05);
        border: 1px solid var(--border-color);
        padding: 1rem 1.5rem;
        border-radius: 12px;
        margin: 0.5rem 0;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-weight: 500;
        transition: background-color 0.2s ease;
      }
      .list-item:hover {
        background: rgba(217, 70, 239, 0.05);
      }
      .bullet {
        width: 8px;
        height: 8px;
        background: var(--neon-gradient);
        border-radius: 50%;
      }
      footer {
        margin-top: 3rem;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.9rem;
      }
  body
    .container
      header
        h1= heading
        .subtitle= title
      nav
        a(href="/") Game Board
        a(href="/db_test") Leaderboard (Pug Table)
        a(href="/db_test/1") Single Record Details
      main
        block content
    footer
